{
  "name": "innerhue-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "InnerHue - A beautifully animated emotional wellness platform",
  "license": "ISC",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "docker:build": "docker build -t innerhue .",
    "docker:run": "docker run -p 3000:3000 innerhue",
    "docker:dev": "docker compose --profile dev up innerhue-dev",
    "docker:prod": "docker compose up innerhue",
    "docker:down": "docker compose down"
  },
  "keywords": [
    "mood tracking",
    "emotional wellness",
    "mental health",
    "visualization"
  ],
  "author": "InnerHue Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nitya-003/InnerHue.git"
  },
  "bugs": {
    "url": "https://github.com/Nitya-003/InnerHue/issues"
  },
  "homepage": "https://Nitya-003.github.io/InnerHue"
}
